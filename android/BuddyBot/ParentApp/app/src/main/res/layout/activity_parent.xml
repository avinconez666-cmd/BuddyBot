<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#0A0E27"
    android:padding="16dp">

    <TextView
        android:id="@+id/connectionStatus"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Status: Disconnected"
        android:textColor="#FF0000"
        android:textStyle="bold"
        android:gravity="center"
        android:padding="8dp"/>

    <TextView
        android:id="@+id/hazardWarning"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="⚠️ HAZARD DETECTED"
        android:textColor="#FFFFFF"
        android:background="#FF0000"
        android:gravity="center"
        android:padding="4dp"
        android:visibility="gone"
        android:layout_marginBottom="8dp"/>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:weightSum="2">
        <TextView
            android:id="@+id/batteryStatus"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🔋 --V"
            android:textColor="#FFFFFF" />
        <TextView
            android:id="@+id/temperatureText"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="🌡️ --°C"
            android:textColor="#FFFFFF"
            android:gravity="end" />
    </LinearLayout>

    <TextView
        android:id="@+id/gpsText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="📍 Searching..."
        android:textColor="#AAAAAA"
        android:textSize="12sp"
        android:layout_marginBottom="8dp" />

    <com.buddybot.parent.RadarView
        android:id="@+id/radarCanvas"
        android:layout_width="match_parent"
        android:layout_height="200dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginVertical="8dp">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mode: "
            android:textColor="#FFFFFF" />
        <Spinner
            android:id="@+id/modeSpinner"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:backgroundTint="#FFFFFF" />
    </LinearLayout>

    <GridLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        android:columnCount="3"
        android:useDefaultMargins="true">
        <View android:layout_width="60dp" android:layout_height="0dp" android:layout_column="0"/>
        <Button android:id="@+id/moveForwardBtn" android:text="▲" android:layout_column="1"/>
        <View android:layout_width="60dp" android:layout_height="0dp" android:layout_column="2"/>
        
        <Button android:id="@+id/moveLeftBtn" android:text="◀" android:layout_row="1" android:layout_column="0"/>
        <Button android:id="@+id/stopBtn" android:text="STOP" android:layout_row="1" android:layout_column="1" android:backgroundTint="#FF0000"/>
        <Button android:id="@+id/moveRightBtn" android:text="▶" android:layout_row="1" android:layout_column="2"/>
        
        <View android:layout_width="60dp" android:layout_height="0dp" android:layout_row="2" android:layout_column="0"/>
        <Button android:id="@+id/moveBackBtn" android:text="▼" android:layout_row="2" android:layout_column="1"/>
    </GridLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/activityLog"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginTop="8dp" />
</LinearLayout>