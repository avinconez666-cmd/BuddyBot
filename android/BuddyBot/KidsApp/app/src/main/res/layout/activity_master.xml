<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_master.xml  —  BuddyBot Kids
    Minimal layout required so MasterActivity compiles.
    MasterActivity is a secondary/backup activity — MainActivity is the
    primary launcher. This layout mirrors activity_main.xml structure.
-->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Robot Face: fullscreen video animations -->
    <VideoView
        android:id="@+id/videoView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center" />

    <!-- Compose UI overlay -->
    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
