<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <!-- Robot Face: ExoPlayer view for precise control over transitions -->
    <androidx.media3.ui.PlayerView
        android:id="@+id/playerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_gravity="center"
        app:resize_mode="fill"
        app:use_controller="false" />

    <!--
        USB Webcam Preview Surface (libausbc)
        Kept at 1x1dp so it occupies no visible space but provides a valid
        surface for the library to render into for frame callbacks.
    -->
    <com.jiangdg.ausbc.widget.AspectRatioTextureView
        android:id="@+id/camera_view"
        android:layout_width="1dp"
        android:layout_height="1dp"
        android:layout_gravity="top|start" />

    <!-- Compose UI: all overlays, dialogs, settings, HUD -->
    <androidx.compose.ui.platform.ComposeView
        android:id="@+id/composeView"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

</FrameLayout>
